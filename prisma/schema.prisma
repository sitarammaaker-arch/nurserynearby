generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String?
  role      Role      @default(USER)
  avatar    String?
  phone     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  reviews   Review[]
  listings  Nursery[] @relation("NurseryOwner")
  @@map("users")
}

enum Role {
  USER
  OWNER
  ADMIN
}

model State {
  id           String     @id @default(cuid())
  name         String     @unique
  slug         String     @unique
  code         String     @unique
  capital      String?
  region       String?
  description  String?
  imageUrl     String?
  nurseryCount Int        @default(0)
  districtCount Int       @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  districts    District[]
  cities       City[]
  nurseries    Nursery[]
  @@index([slug])
  @@map("states")
}

model District {
  id           String    @id @default(cuid())
  name         String
  slug         String
  stateId      String
  description  String?
  imageUrl     String?
  nurseryCount Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  state        State     @relation(fields: [stateId], references: [id])
  cities       City[]
  nurseries    Nursery[]
  @@unique([slug, stateId])
  @@index([stateId])
  @@index([slug])
  @@map("districts")
}

model City {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  state        String
  stateId      String?
  districtId   String?
  country      String    @default("India")
  description  String?
  imageUrl     String?
  nurseryCount Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  nurseries    Nursery[]
  stateRef     State?    @relation(fields: [stateId],    references: [id])
  districtRef  District? @relation(fields: [districtId], references: [id])
  @@index([stateId])
  @@index([districtId])
  @@map("cities")
}

model Category {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  icon        String?
  imageUrl    String?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  nurseries   NurseryCategory[]
  @@map("categories")
}

model Nursery {
  id            String            @id @default(cuid())
  name          String
  slug          String            @unique
  tagline       String?
  description   String?
  phone         String?
  phone2        String?
  whatsapp      String?
  email         String?
  website       String?
  address       String
  landmark      String?
  area          String?
  pincode       String?
  latitude      Float?
  longitude     Float?
  openingHours  String?
  closedOn      String?
  established   Int?
  isVerified    Boolean           @default(false)
  isFeatured    Boolean           @default(false)
  isActive      Boolean           @default(true)
  isPending     Boolean           @default(false)
  avgRating     Float             @default(0)
  totalReviews  Int               @default(0)
  viewCount     Int               @default(0)
  cityId        String
  stateId       String?
  districtId    String?
  ownerId       String?
  importBatch   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  city          City              @relation(fields: [cityId],     references: [id])
  state         State?            @relation(fields: [stateId],    references: [id])
  district      District?         @relation(fields: [districtId], references: [id])
  owner         User?             @relation("NurseryOwner",       fields: [ownerId], references: [id])
  categories    NurseryCategory[]
  reviews       Review[]
  photos        Photo[]
  @@index([cityId])
  @@index([stateId])
  @@index([districtId])
  @@index([slug])
  @@index([isFeatured, isActive])
  @@map("nurseries")
}

model NurseryCategory {
  nurseryId  String
  categoryId String
  nursery    Nursery  @relation(fields: [nurseryId],  references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([nurseryId, categoryId])
  @@map("nursery_categories")
}

model Review {
  id           String   @id @default(cuid())
  rating       Int
  title        String?
  comment      String?
  reviewerName String?
  nurseryId    String
  userId       String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())
  nursery      Nursery  @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  user         User?    @relation(fields: [userId],    references: [id])
  @@map("reviews")
}

model Photo {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  nurseryId String
  createdAt DateTime @default(now())
  nursery   Nursery  @relation(fields: [nurseryId], references: [id], onDelete: Cascade)
  @@map("photos")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  category    String
  tags        String[]
  author      String    @default("NurseryNearby Team")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  readTime    Int       @default(5)
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("blog_posts")
}

model BulkImportLog {
  id          String   @id @default(cuid())
  filename    String
  totalRows   Int
  successRows Int      @default(0)
  failedRows  Int      @default(0)
  errors      Json?
  status      String   @default("processing")
  importedBy  String
  batchId     String   @unique
  createdAt   DateTime @default(now())
  @@map("bulk_import_logs")
}
